<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="UI Tests Suite" verbose="1" parallel="false">
    <test name="VK Video tests">
        <parameter name="appPackage" value="com.vk.vkvideo"/>
        <parameter name="appActivity" value="com.vk.video.screens.main.MainActivity"/>
        <classes>
            <class name="mobile.tests.VkvideoTest"/>
        </classes>
    </test>
    <test name="Alchemy tests">
        <parameter name="appPackage" value="com.ilyin.alchemy"/>
        <parameter name="appActivity" value="com.ilyin.app_google_core.GoogleAppActivity"/>
        <classes>
            <class name="mobile.tests.AlchemyTest"/>
        </classes>
    </test>
</suite>